# Backend Environment Variables
# Copy this file to .env and fill in your own values

# ─────────────────────────────────────────────────────────
# MongoDB Atlas Connection URI
# Get from: https://cloud.mongodb.com → Connect → Drivers
# ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/tree-funding?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────
# JWT Secret Key
# Use a long random string (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ─────────────────────────────────────────────────────────
# Stripe Secret Key
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for sandbox / sk_live_... for production
# ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
